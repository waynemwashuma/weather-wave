{
  "name": "weather-wave",
  "version": "1.0.0",
  "private": true,
  "description": "Weather Wave monorepo.",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm run start -w backend",
    "start:frontend": "npm run start -w frontend",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waynemwashuma/weather-wave.git"
  },
  "bugs": {
    "url": "https://github.com/waynemwashuma/weather-wave/issues"
  },
  "homepage": "https://weather-wave.mwashuma.dev/",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
